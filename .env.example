# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_ACCESS_TOKEN_SECRET=jwt-access-token-secret

# PostgreSQL
POSTGRES_DB=metasphere
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metasphere?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────
# MinIO
#
# MINIO_ROOT_USER / PASSWORD = the admin credentials
# you set when starting MinIO. These are also what your
# app uses as the access/secret key in development.
#
# In production, create a dedicated MinIO service account
# with scoped permissions instead of using root credentials.
#
# MINIO_ENDPOINT: use "minio" (Docker service name) when
# running inside Docker Compose, "localhost" when running
# the NestJS app locally outside Docker.
# ─────────────────────────────────────────────────────────
MINIO_ROOT_USER=metasphere_admin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=metasphere-dev
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=metasphere_admin
MINIO_SECRET_KEY=change_me_minio_password

# File upload limits
MAX_FILE_SIZE_BYTES=10485760   # 10 MB

# ─────────────────────────────────────────────────────────
# Seed — default admin user (development only)
# Override these before running: pnpm db:seed
# ─────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@metasphere.dev
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_FIRSTNAME=Super
SEED_ADMIN_LASTNAME=Admin